[build-system]
requires = ["setuptools>=61.0", "wheel"]
build-backend = "setuptools.build_meta"

[project]
name = "{{ project_name | snake_case }}"
version = "{{ project_version }}"
description = "{{ project_description }}"
readme = "README.md"
requires-python = ">={{ min_python_version }}"
license = {text = "{{ license_type }}"}
authors = [
    {name = "{{ author_name }}"{% if author_email %}, email = "{{ author_email }}"{% endif %}}
]
keywords = ["{{ project_name | snake_case }}"]
classifiers = [
    "Development Status :: 3 - Alpha",
    "Intended Audience :: Developers",
    "License :: OSI Approved :: {{ license_type }} License",
    "Programming Language :: Python :: 3",
    "Programming Language :: Python :: {{ min_python_version }}",
    "Programming Language :: Python :: 3.11",
    "Programming Language :: Python :: 3.12",
    "Typing :: Typed",
]

dependencies = [
{% if has_type_hints %}    "typing-extensions>=4.0.0",{% endif +%}
]

[project.optional-dependencies]
dev = [
{% if include_tests %}    "pytest>=7.4.0",
    "pytest-cov>=4.1.0",
{% if has_async %}    "pytest-asyncio>=0.21.0",{% endif +%}
{% endif %}
{% if include_linting %}    "black>=23.0.0",
    "flake8>=6.0.0",
    "mypy>=1.5.0",
{% endif %}
]
{% if include_docs %}
docs = [
    "mkdocs>=1.5.0",
    "mkdocs-material>=9.0.0",
]
{% endif %}

{% if has_cli %}
[project.scripts]
{{ project_name | snake_case }} = "src.cli:main"
{% endif %}

[project.urls]
Homepage = "https://github.com/{{ author_name | lower | replace(' ', '') }}/{{ project_name | snake_case }}"
Documentation = "https://{{ project_name | snake_case }}.readthedocs.io"
Repository = "https://github.com/{{ author_name | lower | replace(' ', '') }}/{{ project_name | snake_case }}"
Issues = "https://github.com/{{ author_name | lower | replace(' ', '') }}/{{ project_name | snake_case }}/issues"

[tool.setuptools.packages.find]
where = ["."]
include = ["src*"]

{% if include_tests %}
[tool.pytest.ini_options]
testpaths = ["tests"]
python_files = ["test_*.py"]
{% if has_async %}asyncio_mode = "auto"{% endif +%}
addopts = "-v --tb=short"
{% endif %}

[tool.black]
line-length = 88
target-version = ['py{{ min_python_version | replace(".", "") }}']

[tool.mypy]
python_version = "{{ min_python_version }}"
warn_return_any = true
warn_unused_configs = true
strict = true

