<!DOCTYPE html>
<html lang="en"{% if has_dark_mode %} data-theme="light"{% endif %}>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="About {{ project_name }}">
    <meta name="author" content="{{ author_name }}">
    <title>About - {{ project_name }}</title>
    
{% if css_framework == 'bootstrap' %}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
{% elif css_framework == 'tailwind' %}
    <script src="https://cdn.tailwindcss.com"></script>
{% endif %}
    
{% if use_css_variables %}
    <link rel="stylesheet" href="css/variables.css">
{% endif %}
    <link rel="stylesheet" href="css/style.css">
{% if has_responsive %}
    <link rel="stylesheet" href="css/responsive.css">
{% endif %}
</head>
<body>
{% if has_navigation %}
{% if css_framework == 'bootstrap' %}
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand" href="../index.html">{{ project_name }}</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="../index.html">Home</a></li>
                    <li class="nav-item"><a class="nav-link active" href="about.html">About</a></li>
                </ul>
            </div>
        </div>
    </nav>
{% elif css_framework == 'tailwind' %}
    <nav class="bg-blue-600 text-white p-4">
        <div class="container mx-auto flex justify-between items-center">
            <a href="../index.html" class="text-xl font-bold">{{ project_name }}</a>
            <ul class="flex space-x-4">
                <li><a href="../index.html" class="hover:text-blue-200">Home</a></li>
                <li><a href="about.html" class="hover:text-blue-200">About</a></li>
            </ul>
        </div>
    </nav>
{% else %}
    <nav class="navbar">
        <div class="container">
            <a href="../index.html" class="nav-brand">{{ project_name }}</a>
            <ul class="nav-menu">
                <li><a href="../index.html" class="nav-link">Home</a></li>
                <li><a href="about.html" class="nav-link active">About</a></li>
            </ul>
        </div>
    </nav>
{% endif %}
{% endif %}

{% if css_framework == 'bootstrap' %}
    <main class="container my-5">
        <div class="row">
            <div class="col-lg-8 mx-auto">
                <h1 class="display-5 mb-4">About {{ project_name }}</h1>
                <p class="lead">{{ project_description }}</p>
                <hr class="my-4">
                <h2>Features</h2>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item">Feature 1</li>
                    <li class="list-group-item">Feature 2</li>
                    <li class="list-group-item">Feature 3</li>
                </ul>
            </div>
        </div>
    </main>
{% elif css_framework == 'tailwind' %}
    <main class="container mx-auto px-4 py-12">
        <div class="max-w-3xl mx-auto">
            <h1 class="text-3xl font-bold mb-4">About {{ project_name }}</h1>
            <p class="text-lg text-gray-600 mb-8">{{ project_description }}</p>
            <h2 class="text-2xl font-semibold mb-4">Features</h2>
            <ul class="space-y-2">
                <li class="p-3 bg-gray-100 rounded">Feature 1</li>
                <li class="p-3 bg-gray-100 rounded">Feature 2</li>
                <li class="p-3 bg-gray-100 rounded">Feature 3</li>
            </ul>
        </div>
    </main>
{% else %}
    <main class="main-content">
        <div class="container">
            <h1>About {{ project_name }}</h1>
            <p>{{ project_description }}</p>
            <h2>Features</h2>
            <ul>
                <li>Feature 1</li>
                <li>Feature 2</li>
                <li>Feature 3</li>
            </ul>
        </div>
    </main>
{% endif %}

{% if has_footer %}
{% if css_framework == 'bootstrap' %}
    <footer class="bg-dark text-white py-4 mt-auto">
        <div class="container text-center">
            <p class="mb-0">&copy; {{ current_date[:4] }} {{ author_name }}. All rights reserved.</p>
        </div>
    </footer>
{% elif css_framework == 'tailwind' %}
    <footer class="bg-gray-800 text-white py-6 mt-12">
        <div class="container mx-auto text-center">
            <p>&copy; {{ current_date[:4] }} {{ author_name }}. All rights reserved.</p>
        </div>
    </footer>
{% else %}
    <footer class="footer">
        <div class="container">
            <p>&copy; {{ current_date[:4] }} {{ author_name }}. All rights reserved.</p>
        </div>
    </footer>
{% endif %}
{% endif %}

{% if css_framework == 'bootstrap' %}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
{% endif %}
{% if js_type == 'es6_modules' %}
    <script type="module" src="js/main.js"></script>
{% else %}
    <script src="js/main.js"></script>
{% endif %}
</body>
</html>

