/**
 * {{ project_name }} - CSS Variables
 * Author: {{ author_name }}
 */

:root {
    /* Colors */
    --primary-color: #2563eb;
    --primary-hover: #1d4ed8;
    --secondary-color: #64748b;
    --success-color: #22c55e;
    --warning-color: #f59e0b;
    --error-color: #ef4444;
    
    /* Background */
    --bg-color: #ffffff;
    --bg-secondary: #f3f4f6;
    --bg-tertiary: #e5e7eb;
    
    /* Text */
    --text-color: #1f2937;
    --text-muted: #6b7280;
    --heading-color: #111827;
    
    /* Footer */
    --footer-bg: #1f2937;
    --footer-text: #9ca3af;
    
    /* Typography */
    --font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
    --font-size-sm: 0.875rem;
    --font-size-base: 1rem;
    --font-size-lg: 1.25rem;
    --font-size-xl: 2.5rem;
    --line-height: 1.6;
    
    /* Spacing */
    --spacing-xs: 0.25rem;
    --spacing-sm: 0.5rem;
    --spacing-md: 1rem;
    --spacing-lg: 1.5rem;
    --spacing-xl: 2rem;
    
    /* Border */
    --border-radius: 0.375rem;
    --border-color: #e5e7eb;
    
    /* Shadow */
    --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.05);
    --shadow-md: 0 4px 6px rgba(0, 0, 0, 0.1);
    --shadow-lg: 0 10px 15px rgba(0, 0, 0, 0.1);
    
    /* Transitions */
    --transition-fast: 150ms ease;
    --transition-normal: 300ms ease;
}

{% if has_dark_mode %}
/* Dark Theme */
[data-theme="dark"] {
    --primary-color: #3b82f6;
    --primary-hover: #60a5fa;
    
    --bg-color: #111827;
    --bg-secondary: #1f2937;
    --bg-tertiary: #374151;
    
    --text-color: #f3f4f6;
    --text-muted: #9ca3af;
    --heading-color: #ffffff;
    
    --border-color: #374151;
    
    --footer-bg: #0f172a;
    --footer-text: #6b7280;
}
{% endif %}

