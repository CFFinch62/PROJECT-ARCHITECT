# {{ project_name }} - Example Environment Variables
# Copy this file to .env and fill in real values. Never commit .env.

DEBUG=false
HOST=0.0.0.0
PORT={% if web_framework == 'fastapi' %}8000{% elif web_framework == 'django' %}8000{% else %}5000{% endif %}

{% if has_database %}
{% if database_type == 'postgresql' %}
DATABASE_URL=postgresql://user:pass@localhost:5432/{{ project_name | snake_case }}
{% elif database_type == 'mysql' %}
DATABASE_URL=mysql://user:pass@localhost:3306/{{ project_name | snake_case }}
{% elif database_type == 'sqlite' %}
DATABASE_URL=sqlite:///./{{ project_name | snake_case }}.db
{% elif database_type == 'mongodb' %}
DATABASE_URL=mongodb://localhost:27017/{{ project_name | snake_case }}
{% endif %}
{% endif %}

{% if has_authentication %}
SECRET_KEY=change-this-secret-key
{% endif %}

{% if has_caching %}
REDIS_URL=redis://localhost:6379/0
{% endif %}
