Authentication for {{ project_name }}.

{% if auth_type == 'jwt' %}JWT bearer-token authentication.{% elif auth_type == 'session' %}Session-based authentication.{% elif auth_type == 'oauth2' %}OAuth2 authentication.{% endif %}

Author: {{ author_name }}
