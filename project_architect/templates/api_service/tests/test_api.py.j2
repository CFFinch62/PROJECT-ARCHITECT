@pytest.mark.asyncio
class TestItems:
    """Test item endpoints."""
    
    async def test_list_items(self, client, api_base_url):
        """Test listing items."""
        response = await client.get(f"{api_base_url}/items")
        assert response.status_code == 200
        data = response.json()
        assert data["success"] is True
        assert "data" in data
    
    async def test_list_items_pagination(self, client, api_base_url):
        """Test listing items with pagination."""
        response = await client.get(f"{api_base_url}/items?skip=0&limit=5")
        assert response.status_code == 200
        data = response.json()
        assert data["limit"] == 5
    
    async def test_create_item(self, client, api_base_url, sample_item):
        """Test creating an item."""
        response = await client.post(f"{api_base_url}/items", json=sample_item)
        assert response.status_code == 201
        data = response.json()
        assert data["success"] is True
        assert data["data"]["name"] == sample_item["name"]
    
    async def test_get_item(self, client, api_base_url):
        """Test getting a specific item."""
        response = await client.get(f"{api_base_url}/items/1")
        assert response.status_code == 200
        data = response.json()
        assert data["success"] is True
    
    async def test_update_item(self, client, api_base_url, sample_item):
        """Test updating an item."""
        response = await client.put(f"{api_base_url}/items/1", json=sample_item)
        assert response.status_code == 200
        data = response.json()
        assert data["success"] is True
    
    async def test_delete_item(self, client, api_base_url):
        """Test deleting an item."""
        response = await client.delete(f"{api_base_url}/items/1")
        assert response.status_code == 200
        data = response.json()
        assert data["success"] is True


