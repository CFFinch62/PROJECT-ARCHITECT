# {{ project_name }} - Environment Configuration
# Copy this file to .env and update values

# Application
DEBUG=false
HOST=0.0.0.0
PORT={% if api_framework == 'fastapi' %}8000{% else %}5000{% endif %}

{% if has_database %}
# Database
{% if database_type == 'postgresql' %}
DATABASE_URL=postgresql{% if use_async_db %}+asyncpg{% endif %}://user:password@localhost:5432/{{ project_name | snake_case }}
{% elif database_type == 'sqlite' %}
DATABASE_URL=sqlite{% if use_async_db %}+aiosqlite{% endif %}:///./data/{{ project_name | snake_case }}.db
{% endif %}
{% endif %}

{% if has_authentication %}
# Security
SECRET_KEY=your-super-secret-key-change-this-in-production
{% if auth_type == 'jwt' %}
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
{% endif %}
{% endif %}

{% if has_caching %}
# Redis
REDIS_URL=redis://localhost:6379/0
{% endif %}

{% if has_cors %}
# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
{% endif %}

{% if has_rate_limiting %}
# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
{% endif %}

