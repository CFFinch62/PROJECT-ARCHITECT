{% elif api_framework == 'flask' %}
from flask_restx import Namespace, Resource, fields

api_ns = Namespace("api", description="API v1 operations")

# Models for documentation
item_model = api_ns.model("Item", {
    "id": fields.Integer(description="Item ID"),
    "name": fields.String(required=True, description="Item name"),
    "description": fields.String(description="Item description")
})

success_model = api_ns.model("Success", {
    "success": fields.Boolean(description="Operation success"),
    "message": fields.String(description="Response message"),
    "data": fields.Raw(description="Response data")
})


@api_ns.route("/")
class ApiInfo(Resource):
    def get(self):
        """Get API information."""
        return {"success": True, "message": "API v1", "data": {"version": "1.0"}}


@api_ns.route("/items")
class ItemList(Resource):
    @api_ns.marshal_list_with(item_model)
    def get(self):
        """List all items."""
        return [{"id": i, "name": f"Item {i}"} for i in range(10)]
    
    @api_ns.expect(item_model)
    @api_ns.marshal_with(success_model, code=201)
    def post(self):
        """Create a new item."""
        return {"success": True, "message": "Item created"}, 201


@api_ns.route("/items/<int:item_id>")
class ItemResource(Resource):
    @api_ns.marshal_with(item_model)
    def get(self, item_id):
        """Get item by ID."""
        return {"id": item_id, "name": f"Item {item_id}"}
    
    @api_ns.expect(item_model)
    @api_ns.marshal_with(success_model)
    def put(self, item_id):
        """Update item."""
        return {"success": True, "message": "Item updated"}
    
    @api_ns.marshal_with(success_model)
    def delete(self, item_id):
        """Delete item."""
        return {"success": True, "message": "Item deleted"}
