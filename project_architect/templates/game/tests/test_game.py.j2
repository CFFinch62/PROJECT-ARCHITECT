{% if game_framework == 'pygame' %}
class TestGame:
    """Tests for the Pygame Game class (headless, no display required)."""

    @pytest.fixture
    def game(self, config):
        import pygame

        pygame.init()
        surface = pygame.Surface((config.screen_width, config.screen_height))
        from src.game import Game

        return Game(surface, config)

    def test_initial_state(self, game, config):
        assert game.running is True
        {% if has_score_tracking %}
        assert game.score == config.starting_score
        {% endif %}

    def test_draw_does_not_raise(self, game):
        game.draw()

    def test_escape_key_stops_game(self, game):
        import pygame

        game.on_key_down(pygame.K_ESCAPE)
        assert game.running is False


