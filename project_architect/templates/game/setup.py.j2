#!/usr/bin/env python3
"""
Setup script for {{ project_name }}

Author: {{ author_name }}{{ " <" + author_email + ">" if author_email else "" }}
{{ "Organization: " + organization if organization else "" }}
"""

from setuptools import setup, find_packages
from pathlib import Path

# Read README for long description
readme_file = Path(__file__).parent / "README.md"
long_description = readme_file.read_text(encoding="utf-8") if readme_file.exists() else ""

setup(
    name="{{ project_name | snake_case }}",
    version="{{ project_version }}",
    author="{{ author_name }}",
    {% if author_email %}author_email="{{ author_email }}",{% endif +%}
    description="{{ project_description }}",
    long_description=long_description,
    long_description_content_type="text/markdown",
    {% if organization %}url="https://github.com/{{ organization | snake_case }}/{{ project_name | snake_case }}",{% endif +%}
    packages=find_packages(),
    classifiers=[
        "Development Status :: 3 - Alpha",
        "Intended Audience :: Developers",
        "Programming Language :: Python :: 3",
        "Programming Language :: Python :: 3.12",
        "Topic :: Games/Entertainment",
        "License :: OSI Approved :: MIT License",
        "Operating System :: OS Independent",
    ],
    python_requires=">=3.12",
    install_requires=[
        {% if game_framework == 'pygame' %}"pygame>=2.5.0",
        {% elif game_framework == 'arcade' %}"arcade>=2.6.17",
        {% elif game_framework == 'pyglet' %}"pyglet>=2.0.0",
        {% elif game_framework == 'pgzero' %}"pgzero>=1.2.1",
        {% endif %}
        "python-dateutil>=2.8.0",
    ],
    extras_require={
        "dev": [
            {% if include_tests %}"pytest>=7.4.0",
            "pytest-cov>=4.1.0",
            "pytest-mock>=3.11.0",
            {% endif %}
            {% if include_linting %}"flake8>=6.0.0",
            "pylint>=2.17.0",
            {% endif %}
            {% if include_formatting %}"black>=23.0.0",{% endif +%}
            {% if include_type_checking %}"mypy>=1.5.0",{% endif +%}
        ],
    },
    entry_points={
        "console_scripts": [
            "{{ project_name | snake_case }}=main:main",
        ],
    },
    include_package_data=True,
    zip_safe=False,
)
