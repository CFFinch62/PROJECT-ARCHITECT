@pytest.fixture
def mock_logger(monkeypatch):
    """
    Provide a mock logger for testing without file I/O.
    
    Args:
        monkeypatch: pytest's monkeypatch fixture
    
    Returns:
        List to store log messages
    """
    log_messages = []
    
    def mock_log(level, message):
        log_messages.append((level, message))
    
    # Patch logging functions
    import logging
    monkeypatch.setattr(logging, 'debug', lambda msg: mock_log('DEBUG', msg))
    monkeypatch.setattr(logging, 'info', lambda msg: mock_log('INFO', msg))
    monkeypatch.setattr(logging, 'warning', lambda msg: mock_log('WARNING', msg))
    monkeypatch.setattr(logging, 'error', lambda msg: mock_log('ERROR', msg))
    
    return log_messages


# Markers for test categorization

def pytest_configure(config):
    """Configure custom pytest markers."""
    config.addinivalue_line(
        "markers", "slow: marks tests as slow (deselect with '-m \"not slow\"')"
    )
    config.addinivalue_line(
        "markers", "integration: marks tests as integration tests"
    )
    config.addinivalue_line(
        "markers", "unit: marks tests as unit tests"
    )
    config.addinivalue_line(
        "markers", "gui: marks tests that require GUI"
    )


# Test hooks

def pytest_collection_modifyitems(config, items):
    """Modify test collection to add markers automatically."""
    for item in items:
        # Mark tests in integration folders
        if "integration" in str(item.fspath):
            item.add_marker(pytest.mark.integration)
        # Mark GUI tests
        if "test_main_window" in str(item.fspath):
            item.add_marker(pytest.mark.gui)
