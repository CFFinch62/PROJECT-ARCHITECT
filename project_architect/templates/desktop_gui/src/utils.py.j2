{% if has_logging %}
def setup_logging(log_dir: Optional[Path] = None, log_level: str = "{{ log_level }}") -> logging.Logger:
    """
    Set up logging for the application.
    
    Args:
        log_dir: Directory for log files (default: ./logs)
        log_level: Logging level (default: {{ log_level }})
        
    Returns:
        Configured logger instance
    """
    if log_dir is None:
        log_dir = Path("logs")
    
    # Create log directory
    log_dir.mkdir(parents=True, exist_ok=True)
    
    # Configure logging
    log_file = log_dir / f"{{ project_name | snake_case }}.log"
    
    logging.basicConfig(
        level=getattr(logging, log_level.upper()),
        format="%(asctime)s - %(name)s - %(levelname)s - %(message)s",
        handlers=[
            logging.FileHandler(log_file),
            logging.StreamHandler(sys.stdout)
        ]
    )
    
    logger = logging.getLogger("{{ project_name | snake_case }}")
    logger.info("Logging initialized")
    
    return logger
{% endif %}


def get_app_dir() -> Path:
    """
    Get the application directory.
    
    Returns:
        Path to the application directory
    """
    if getattr(sys, 'frozen', False):
        # Running as compiled executable
        app_dir = Path(sys.executable).parent
    else:
        # Running as script
        app_dir = Path(__file__).parent.parent
    
    return app_dir


def get_data_dir() -> Path:
    """
    Get the application data directory.
    
    Returns:
        Path to the data directory
    """
    data_dir = get_app_dir() / "data"
    data_dir.mkdir(parents=True, exist_ok=True)
    return data_dir


def get_assets_dir() -> Path:
    """
    Get the assets directory.
    
    Returns:
        Path to the assets directory
    """
    return get_app_dir() / "assets"


def format_timestamp(dt: Optional[datetime] = None, format_str: str = "%Y-%m-%d %H:%M:%S") -> str:
    """
    Format a datetime object as a string.
    
    Args:
        dt: Datetime object (default: current time)
        format_str: Format string (default: YYYY-MM-DD HH:MM:SS)
        
    Returns:
        Formatted timestamp string
    """
    if dt is None:
        dt = datetime.now()
    
    return dt.strftime(format_str)


def ensure_dir(path: Union[str, Path]) -> Path:
    """
    Ensure a directory exists, creating it if necessary.
    
    Args:
        path: Path to directory
        
    Returns:
        Path object for the directory
    """
    path = Path(path)
    path.mkdir(parents=True, exist_ok=True)
    return path


def safe_read_file(file_path: Union[str, Path], default: str = "") -> str:
    """
    Safely read a file, returning default value on error.
    
    Args:
        file_path: Path to file
        default: Default value to return on error
        
    Returns:
        File contents or default value
    """
    try:
        return Path(file_path).read_text(encoding='utf-8')
    except Exception{% if has_logging %} as e{% endif %}:
        {% if has_logging %}
        logger = logging.getLogger(__name__)
        logger.error(f"Failed to read file {file_path}: {e}")
        {% endif %}
        return default


def safe_write_file(file_path: Union[str, Path], content: str) -> bool:
    """
    Safely write content to a file.
    
    Args:
        file_path: Path to file
        content: Content to write
        
    Returns:
        True if successful, False otherwise
    """
    try:
        file_path = Path(file_path)
        file_path.parent.mkdir(parents=True, exist_ok=True)
        file_path.write_text(content, encoding='utf-8')
        return True
    except Exception{% if has_logging %} as e{% endif %}:
        {% if has_logging %}
        logger = logging.getLogger(__name__)
        logger.error(f"Failed to write file {file_path}: {e}")
        {% endif %}
        return False


