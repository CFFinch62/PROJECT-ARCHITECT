from pathlib import Path
from typing import Any, Dict, Optional
{% if has_logging %}
import logging
{% endif %}


class AppConfig:
    """Application configuration manager."""
    
    def __init__(self, config_file: Optional[Path] = None):
        """
        Initialize configuration manager.
        
        Args:
            config_file: Path to configuration file (default: config.{% if config_format == 'json' %}json{% elif config_format == 'yaml' %}yaml{% elif config_format == 'ini' %}ini{% elif config_format == 'toml' %}toml{% endif %})
        """
        {% if has_logging %}
        self.logger = logging.getLogger(__name__)
        {% endif %}
        
        if config_file is None:
            config_file = Path("config.{% if config_format == 'json' %}json{% elif config_format == 'yaml' %}yaml{% elif config_format == 'ini' %}ini{% elif config_format == 'toml' %}toml{% endif %}")
        
        self.config_file = Path(config_file)
        self.config: Dict[str, Any] = {}
        
        # Default configuration
        self._set_defaults()
    
    def _set_defaults(self):
        """Set default configuration values."""
        self.config = {
            "application": {
                "name": "{{ project_name }}",
                "version": "{{ project_version }}",
                "author": "{{ author_name }}",
            },
            {% if gui_framework == 'customtkinter' %}
            "appearance": {
                "theme": "{{ app_theme }}",
                "color_scheme": "{{ color_scheme }}",
            },
            {% endif %}
            {% if has_logging %}
            "logging": {
                "level": "{{ log_level }}",
                "file": "logs/{{ project_name | snake_case }}.log",
            },
            {% endif %}
            {% if has_database %}
            "database": {
                "type": "{{ database_type }}",
                {% if database_type == 'sqlite' %}
                "path": "data/{{ project_name | snake_case }}.db",
                {% elif database_type in ['postgresql', 'mysql'] %}
                "host": "localhost",
                "port": {% if database_type == 'postgresql' %}5432{% else %}3306{% endif %},
                "database": "{{ project_name | snake_case }}",
                "username": "user",
                "password": "",
                {% elif database_type == 'mongodb' %}
                "host": "localhost",
                "port": 27017,
                "database": "{{ project_name | snake_case }}",
                {% endif %}
            },
            {% endif %}
        }
    
    def load_config(self) -> bool:
        """
        Load configuration from file.
        
        Returns:
            bool: True if loaded successfully, False otherwise
        """
        try:
            if not self.config_file.exists():
                {% if has_logging %}
                self.logger.info(f"Configuration file not found: {self.config_file}")
                self.logger.info("Creating default configuration")
                {% endif %}
                self.save_config()
                return True
            
            {% if config_format == 'json' %}
            with open(self.config_file, 'r', encoding='utf-8') as f:
                loaded_config = json.load(f)
            {% elif config_format == 'yaml' %}
            with open(self.config_file, 'r', encoding='utf-8') as f:
                loaded_config = yaml.safe_load(f)
            {% elif config_format == 'ini' %}
            parser = configparser.ConfigParser()
            parser.read(self.config_file)
            loaded_config = {section: dict(parser[section]) for section in parser.sections()}
            {% elif config_format == 'toml' %}
            with open(self.config_file, 'rb') as f:
                loaded_config = tomllib.load(f)
            {% endif %}
            
            # Merge with defaults (preserve any new default keys)
            self._merge_config(loaded_config)
            
            {% if has_logging %}
            self.logger.info(f"Configuration loaded from {self.config_file}")
            {% endif %}
            return True
            
        except Exception as e:
            {% if has_logging %}
            self.logger.error(f"Failed to load configuration: {e}")
            {% endif %}
            return False
    
    def save_config(self) -> bool:
        """
        Save configuration to file.
        
        Returns:
            bool: True if saved successfully, False otherwise
        """
        try:
            # Create parent directory if it doesn't exist
            self.config_file.parent.mkdir(parents=True, exist_ok=True)
            
            {% if config_format == 'json' %}
            with open(self.config_file, 'w', encoding='utf-8') as f:
                json.dump(self.config, f, indent=2)
            {% elif config_format == 'yaml' %}
            with open(self.config_file, 'w', encoding='utf-8') as f:
                yaml.dump(self.config, f, default_flow_style=False)
            {% elif config_format == 'ini' %}
            parser = configparser.ConfigParser()
            for section, values in self.config.items():
                parser[section] = {k: str(v) for k, v in values.items()}
            with open(self.config_file, 'w', encoding='utf-8') as f:
                parser.write(f)
            {% elif config_format == 'toml' %}
            with open(self.config_file, 'wb') as f:
                tomli_w.dump(self.config, f)
            {% endif %}
            
            {% if has_logging %}
            self.logger.info(f"Configuration saved to {self.config_file}")
            {% endif %}
            return True
            
        except Exception as e:
            {% if has_logging %}
            self.logger.error(f"Failed to save configuration: {e}")
            {% endif %}
            return False
    
    def get(self, key: str, default: Any = None) -> Any:
        """
        Get configuration value by key.
        
        Args:
            key: Configuration key (supports dot notation, e.g., 'application.name')
            default: Default value if key not found
            
        Returns:
            Configuration value or default
        """
        try:
            keys = key.split('.')
            value = self.config
            for k in keys:
                value = value[k]
            return value
        except (KeyError, TypeError):
            return default
    
    def set(self, key: str, value: Any) -> bool:
        """
        Set configuration value by key.
        
        Args:
            key: Configuration key (supports dot notation)
            value: Value to set
            
        Returns:
            bool: True if set successfully
        """
        try:
            keys = key.split('.')
            config = self.config
            for k in keys[:-1]:
                if k not in config:
                    config[k] = {}
                config = config[k]
            config[keys[-1]] = value
            return True
        except Exception as e:
            {% if has_logging %}
            self.logger.error(f"Failed to set configuration value: {e}")
            {% endif %}
            return False
    
    def _merge_config(self, loaded_config: Dict[str, Any]):
        """
        Merge loaded configuration with defaults.
        
        Args:
            loaded_config: Configuration loaded from file
        """
        def merge_dict(base: dict, update: dict) -> dict:
            """Recursively merge two dictionaries."""
            result = base.copy()
            for key, value in update.items():
                if key in result and isinstance(result[key], dict) and isinstance(value, dict):
                    result[key] = merge_dict(result[key], value)
                else:
                    result[key] = value
            return result
        
        self.config = merge_dict(self.config, loaded_config)

