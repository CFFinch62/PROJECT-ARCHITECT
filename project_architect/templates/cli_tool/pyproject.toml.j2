[build-system]
requires = ["setuptools>=61.0", "wheel"]
build-backend = "setuptools.build_meta"

[project]
name = "{{ project_name | snake_case }}"
version = "{{ project_version }}"
description = "{{ project_description }}"
readme = "README.md"
requires-python = ">=3.12"
license = {text = "MIT"}
authors = [
    {name = "{{ author_name }}"{% if author_email %}, email = "{{ author_email }}"{% endif %}}
]
classifiers = [
    "Development Status :: 3 - Alpha",
    "Environment :: Console",
    "Intended Audience :: Developers",
    "License :: OSI Approved :: MIT License",
    "Operating System :: OS Independent",
    "Programming Language :: Python :: 3",
    "Programming Language :: Python :: 3.12",
]
dependencies = [
{% if cli_framework == 'click' %}    "click>=8.1.0",
{% elif cli_framework == 'typer' %}    "typer>=0.9.0",
    "rich>=13.0.0",
{% endif %}
{% if has_config_file %}{% if config_format == 'yaml' %}    "pyyaml>=6.0.0",
{% elif config_format == 'toml' %}    "tomli>=2.0.0",
{% endif %}{% endif +%}
]

[project.optional-dependencies]
dev = [
{% if include_tests %}    "pytest>=7.4.0",
    "pytest-cov>=4.1.0",
{% endif %}
{% if include_linting %}    "flake8>=6.0.0",
    "pylint>=2.17.0",
{% endif %}
]

[project.scripts]
{{ project_name | snake_case }} = "{{ project_name | snake_case }}:main"

[project.urls]
Homepage = "https://github.com/{{ author_name | lower | replace(' ', '') }}/{{ project_name | snake_case }}"

[tool.setuptools.packages.find]
where = ["."]

{% if include_tests %}
[tool.pytest.ini_options]
testpaths = ["tests"]
python_files = ["test_*.py"]
python_functions = ["test_*"]
addopts = "-v --tb=short"
{% endif %}

[tool.black]
line-length = 88
target-version = ['py312']
include = '\.pyi?$'

